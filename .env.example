# BTC 定投指标监控系统 - 环境变量配置

# ============================================================
# API 代理配置（解决 CORS 问题）
# ============================================================

# 本地开发时代理服务器地址
# 如果使用 proxy-server.js，设置为: http://localhost:3001/api
# 如果使用 Vercel Edge Function，不需要设置（使用相对路径 /api）
# 如果直接访问（会有 CORS 问题），留空
VITE_API_PROXY_URL=http://localhost:3001/api

# ============================================================
# 数据更新服务配置（可选）
# ============================================================

# 自动刷新间隔（秒，默认 600 = 10分钟）
# BTC_UPDATE_INTERVAL=600

# 每日更新时间（逗号分隔，默认 08:00,20:00）
# BTC_UPDATE_TIME=08:00,20:00

# 输出文件路径（可选，默认 app/public/btc_indicators_history.json）
# BTC_OUTPUT_FILE=

# 日志级别（DEBUG, INFO, WARNING, ERROR，默认 INFO）
# BTC_LOG_LEVEL=INFO

# 禁用日志文件（仅输出到控制台）
# BTC_NO_LOG_FILE=true

# ============================================================
# 部署配置（Vercel/Netlify 等）
# ============================================================

# Vercel Edge Function API 地址（部署后自动设置）
# VERCEL_API_URL=
