{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "name": "btc-dca-monitor",
  "buildCommand": "cd app && npm run build",
  "installCommand": "cd app && npm ci",
  "outputDirectory": "app/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/btc-data/(.*)",
      "destination": "/api/btc-data?path=/btc-data/$1"
    },
    {
      "source": "/api/btc-data",
      "destination": "/api/btc-data?path=/btc-data"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/btc_indicators_latest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=300, stale-while-revalidate=600"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/btc_indicators_history_light.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=1800, stale-while-revalidate=3600"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/btc_indicators_history.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=1800, s-maxage=21600, stale-while-revalidate=43200"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/btc_indicators_manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=60, s-maxage=300, stale-while-revalidate=600"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}
